# Copy to .env and fill in your values. Do not commit .env.

# Comma-separated tickers
TICKERS=AAPL,GOOG,MSFT

# Email (for daily digest)
SEND_TO=you@example.com
SEND_FROM=you@example.com

# Timezone for report date
TIMEZONE=America/New_York

# Google OAuth (Gmail API) - create in Google Cloud Console
CLIENT_ID=your-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-client-secret

# APIs (Polygon.io, Finnhub, etc.)
POLYGON_API_KEY=
FINNHUB_API_KEY=
SERPAPI_KEY=
OPENAI_API_KEY=

# Optional
LLM_MODEL=gpt-4o-mini
RISK_FREE_RATE=0.04
BOOTSTRAP_DAYS=365
PREVIEW_ONLY=0
MONEYNESS_PCT=0.15
