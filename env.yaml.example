# Copy to env.yaml and fill in secrets. Do not commit env.yaml.
# The Cloud Function uses ONLY env.yaml (not .env). To use the latest ticker list,
# ordering, and code: keep env.yaml in sync with .env (or this file), then run ./quick_deploy.sh

# --- Required for Cloud Run (same as .env) ---
POLYGON_API_KEY: "your-polygon-api-key"
TICKERS: "SPY,QQQ,AAPL,ADBE,AMZN,APP,BRK.B,COIN,CRCL,DPZ,FICO,FTNT,GOOG,HOOD,IBIT,IBM,KLAC,LRCX,META,MSCI,MSFT,MSTR,NVDA,GLD,GDX,SLV,SIL,CPER,COPX"
SEND_FROM: "you@example.com"
SEND_TO: "team@example.com"
GMAIL_TOKEN_JSON: '{"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.send", "https://www.googleapis.com/auth/gmail.compose"]}'

# --- Optional (defaults used if omitted) ---
TIMEZONE: "America/New_York"
SUBJECT_PREFIX: "Options Dashboard"
PREVIEW_ONLY: "0"
MONEYNESS_PCT: "0.15"
FINNHUB_API_KEY: ""
# MAX_TICKERS_PER_RUN is optional; default is length of TICKERS list
