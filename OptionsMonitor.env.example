# Copy this file to OptionsMonitor.env and fill in your values.
# Put OptionsMonitor.env in the same folder as the Options Monitor app.

# Required: your Polygon API key (Options plan)
POLYGON_API_KEY=your_polygon_key_here

# Comma-separated tickers to show
TICKERS=AAPL,MSFT,GOOG,META,NVDA

# Optional
# MONEYNESS_PCT=0.15
# MAX_TICKERS_PER_RUN=15
# TIMEZONE=America/New_York
# SUBJECT_PREFIX=Options Dashboard

# Optional: for headline scoring (OpenAI). If missing, headlines still show but with less filtering.
# OPENAI_API_KEY=your_openai_key_here
# LLM_MODEL=gpt-4o-mini
